# Local PostgreSQL bootstrap values for Docker Compose
POSTGRES_DB=contextos_local
POSTGRES_MIGRATION_USER=contextos_migration
POSTGRES_MIGRATION_PASSWORD=replace-with-local-migration-password
POSTGRES_APP_USER=contextos_app
POSTGRES_APP_PASSWORD=replace-with-local-runtime-password

# Application settings
CONTEXTOS_APPLICATION_NAME=contextos-api
CONTEXTOS_APPLICATION_VERSION=0.1.0
CONTEXTOS_ENVIRONMENT=local
CONTEXTOS_LOG_LEVEL=INFO
CONTEXTOS_LOG_FORMAT=console
CONTEXTOS_READINESS_TIMEOUT_SECONDS=3

# Host-executed backend infrastructure URLs
CONTEXTOS_DATABASE_URL=postgresql+asyncpg://contextos_app:replace-with-local-runtime-password@127.0.0.1:15432/contextos_local
CONTEXTOS_MIGRATION_DATABASE_URL=postgresql+asyncpg://contextos_migration:replace-with-local-migration-password@127.0.0.1:15432/contextos_local
CONTEXTOS_REDIS_URL=redis://127.0.0.1:6379/0

# Supabase Auth backend configuration
CONTEXTOS_SUPABASE_URL=https://your-project.supabase.co
CONTEXTOS_SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
CONTEXTOS_SUPABASE_JWT_AUDIENCE=authenticated
CONTEXTOS_SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
CONTEXTOS_SUPABASE_SECRET_KEY=replace-with-server-secret-key
CONTEXTOS_FRONTEND_URL=http://localhost:3000
CONTEXTOS_BETA_MAX_USERS=3
CONTEXTOS_DOCUMENT_STORAGE_ROOT=data/private-documents
CONTEXTOS_DOCUMENT_MAX_PER_USER=10
CONTEXTOS_DOCUMENT_MAX_PDF_SIZE_BYTES=10485760
CONTEXTOS_DOCUMENT_MAX_TOTAL_SIZE_BYTES=52428800
CONTEXTOS_DOCUMENT_MAX_PAGES=100
CONTEXTOS_DOCUMENT_CHUNK_SIZE=1800
CONTEXTOS_DOCUMENT_CHUNK_OVERLAP=200
CONTEXTOS_DOCUMENT_QUEUE_NAME=contextos-ingestion
CONTEXTOS_RETRIEVAL_SIMILARITY_THRESHOLD=0.72
CONTEXTOS_RETRIEVAL_TOP_K=5
CONTEXTOS_RETRIEVAL_MAX_CONTEXT_CHARACTERS=9000
CONTEXTOS_LLM_PROVIDER=fake
CONTEXTOS_LLM_MODEL=gemini-2.5-flash
CONTEXTOS_EMBEDDING_PROVIDER=fake
CONTEXTOS_EMBEDDING_MODEL=text-embedding-004
CONTEXTOS_EMBEDDING_DIMENSION=768
CONTEXTOS_AI_PROVIDER_TIMEOUT_SECONDS=12
CONTEXTOS_AI_PROVIDER_MAX_RETRIES=2
CONTEXTOS_AI_PROVIDER_API_KEY=
CONTEXTOS_AI_DAILY_MESSAGE_LIMIT=20
CONTEXTOS_AI_MONTHLY_MESSAGE_LIMIT=200

# Frontend-safe configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CONTEXTOS_API_URL=http://127.0.0.1:8000
