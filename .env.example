# ContextOS environment variables are finalized in later milestones.

# App identity
APP_NAME=ContextOS
APP_ENV=development

# Authentication
AUTH_PROVIDER_PLACEHOLDER=placeholder-value
AUTH_JWT_SECRET_PLACEHOLDER=placeholder-value

# Database
DATABASE_URL_PLACEHOLDER=placeholder-value

# Object storage
STORAGE_BUCKET_PLACEHOLDER=placeholder-value

# Background jobs
REDIS_URL_PLACEHOLDER=placeholder-value

# AI providers
AI_PROVIDER_PLACEHOLDER=placeholder-value
AI_API_KEY_PLACEHOLDER=placeholder-value

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_PLACEHOLDER=placeholder-value
